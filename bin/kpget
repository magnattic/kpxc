#!/usr/bin/env bash
# kpget - retrieve a field from a KeePass entry using the cached master password.
#
# Usage:
#   kpget <entry-path>             # default: print Password attribute
#   kpget <entry-path> -a Username # any keepassxc-cli show option
#
# Configuration: see kpunlock(1).

set -euo pipefail

CACHE="${KP_CACHE:-/dev/shm/$(id -u)-kpxc}"
CONFIG="${KP_CONFIG:-$HOME/.config/kpxc/config}"

_safe_source() {
  local cfg="$1"
  [[ -f "$cfg" ]] || return 0
  if [[ ! -O "$cfg" ]]; then
    echo "kpget: refusing to source $cfg (not owned by you)." >&2
    return 1
  fi
  local perms
  perms=$(ls -ld "$cfg" 2>/dev/null | awk '{print $1}')
  if [[ "${perms:5:1}" == "w" || "${perms:8:1}" == "w" ]]; then
    echo "kpget: refusing to source $cfg (group/world-writable)." >&2
    return 1
  fi
  # shellcheck source=/dev/null
  source "$cfg"
}

_safe_source "$CONFIG"

DB="${KP_DB:-}"
KEYFILE="${KP_KEYFILE:-}"

if [[ -z "$DB" ]]; then
  echo "kpget: no database configured (set \$KP_DB env var or KP_DB= in config)." >&2
  exit 1
fi

if [[ $# -lt 1 ]]; then
  echo "Usage: kpget <entry-path> [keepassxc-cli show options...]" >&2
  exit 2
fi

if [[ ! -f "$CACHE" ]]; then
  echo "kpget: no cached master password - run 'kpunlock' first." >&2
  exit 1
fi

# Optional TTL check (portable mtime: GNU stat -c, BSD/macOS stat -f).
if [[ -n "${KP_TTL:-}" ]]; then
  if mtime=$(stat -c %Y "$CACHE" 2>/dev/null); then :
  elif mtime=$(stat -f %m "$CACHE" 2>/dev/null); then :
  else
    echo "kpget: could not read cache mtime - run 'kpunlock' again." >&2
    exit 1
  fi
  age=$(( $(date +%s) - mtime ))
  if (( age > KP_TTL )); then
    echo "kpget: cache expired (>${KP_TTL}s) - run 'kpunlock' again." >&2
    exit 1
  fi
fi

ENTRY="$1"; shift

# Default to Password attribute when no show options given
if [[ "$#" -eq 0 ]]; then
  set -- -s -a Password
fi

extra_args=()
[[ -n "$KEYFILE" ]] && extra_args+=(--key-file "$KEYFILE")

# Run keepassxc-cli; let its error messages surface directly so the user
# sees the actual cause (wrong entry path, locked DB, etc.) instead of a
# generic "cache stale" hint that's often wrong.
keepassxc-cli show -q "${extra_args[@]}" "$@" "$DB" -- "$ENTRY" < "$CACHE"
