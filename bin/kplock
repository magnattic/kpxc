#!/usr/bin/env bash
# kplock - clear the cached KeePass master password.
#
# Note: shred has no effect on tmpfs (RAM-backed, no physical blocks),
# so we just unlink - the kernel reclaims the pages.

set -euo pipefail

CONFIG="${KP_CONFIG:-$HOME/.config/kpxc/config}"

_safe_source() {
  local cfg="$1"
  [[ -f "$cfg" ]] || return 0
  if [[ ! -O "$cfg" ]]; then
    echo "kplock: refusing to source $cfg (not owned by you)." >&2
    return 1
  fi
  local mode
  mode=$(stat -c '%a' "$cfg" 2>/dev/null) || mode=$(stat -f '%OLp' "$cfg" 2>/dev/null) || mode=""
  if [[ -z "$mode" ]]; then
    echo "kplock: cannot stat $cfg" >&2
    return 1
  fi
  if (( 8#$mode & 022 )); then
    echo "kplock: refusing to source $cfg (mode $mode, group/world-writable)." >&2
    return 1
  fi
  # shellcheck source=/dev/null
  source "$cfg"
}

_safe_source "$CONFIG"

CACHE="${KP_CACHE:-/dev/shm/$(id -u)-kpxc}"

if [[ -f "$CACHE" ]]; then
  rm -f "$CACHE"
  echo "Cache cleared"
else
  echo "(no cache)"
fi
