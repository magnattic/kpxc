#!/usr/bin/env bash
# kpxc - cached wrapper around keepassxc-cli with two unlock modes:
#
#   scope mode (default): cache only specific entries' fields. Master
#                         password is used briefly during unlock and
#                         then discarded. An attacker reading the cache
#                         only gets the scoped credentials, not the
#                         whole database. The chosen scope is persisted
#                         to ~/.config/kpxc/scope and reused on the next
#                         'kpxc unlock'.
#
#   master mode (opt-in): cache the master password. Allows any
#                         keepassxc-cli subcommand (ls, search, add,
#                         edit). Activated by 'kpxc unlock --master'.
#
# Subcommands:
#   kpxc unlock [<scope-spec>...]                cache scoped credentials
#   kpxc unlock --interactive                    re-pick scope via prompt
#   kpxc unlock --master                         cache master password
#   kpxc lock                                    clear all caches
#   kpxc get <entry> [-a <field>]                read a cached value
#   kpxc scope                                   show what's cached
#   kpxc <keepassxc-subcmd> [args...]            forward to keepassxc-cli
#                                                (requires master mode)
#
# Scope-spec syntax (CLI and scope file):
#   Email/personal                  default field (Password)
#   Email/personal:Username         specific field
#   Email/personal:Password,URL     multiple fields on one entry
#
# Configuration:
#   $KPXC_DB        path to .kdbx (required)
#   $KPXC_KEYFILE   optional key file
#   $KPXC_TTL       optional cache TTL in seconds
#   $KPXC_CACHE     override cache directory (default /dev/shm/<uid>-kpxc.d)
#   $KPXC_RC        override config file path (default ~/.config/kpxc/config)
#   $KPXC_SCOPE     override scope file path  (default ~/.config/kpxc/scope)

set -euo pipefail

CACHE_DIR="${KPXC_CACHE:-/dev/shm/$(id -u)-kpxc.d}"
CACHE_MASTER="$CACHE_DIR/master"
CACHE_SCOPED="$CACHE_DIR/scoped"
CONFIG="${KPXC_RC:-$HOME/.config/kpxc/config}"
SCOPE_FILE="${KPXC_SCOPE:-$HOME/.config/kpxc/scope}"

_safe_perm_check() {
  local file="$1"
  if [[ ! -O "$file" ]]; then
    echo "kpxc: refusing to read $file (not owned by you)." >&2
    return 1
  fi
  local mode
  mode=$(stat -c '%a' "$file" 2>/dev/null) || mode=$(stat -f '%OLp' "$file" 2>/dev/null) || mode=""
  if [[ -z "$mode" ]]; then
    echo "kpxc: cannot stat $file" >&2
    return 1
  fi
  if (( 8#$mode & 022 )); then
    echo "kpxc: refusing to read $file (mode $mode, group/world-writable). Run: chmod 600 '$file'" >&2
    return 1
  fi
  return 0
}

_safe_source() {
  local cfg="$1"
  [[ -f "$cfg" ]] || return 0
  _safe_perm_check "$cfg" || return 1
  # shellcheck source=/dev/null
  source "$cfg" || true
  return 0
}

_safe_source "$CONFIG"

DB="${KPXC_DB:-}"
KEYFILE="${KPXC_KEYFILE:-}"

# Migration guard: v0.3.x used a single file at /dev/shm/<uid>-kpxc. If we
# find such a file at the path our directory should occupy, refuse rather
# than silently shred user state.
if [[ -f "$CACHE_DIR" ]]; then
  echo "kpxc: legacy v0.3.x cache file at $CACHE_DIR conflicts with the new" >&2
  echo "  cache-directory layout. Remove it: rm '$CACHE_DIR'" >&2
  exit 1
fi

_require_db() {
  if [[ -z "$DB" ]]; then
    echo "kpxc: no database configured (set \$KPXC_DB env var or KPXC_DB= in $CONFIG)." >&2
    exit 1
  fi
}

_extra_args() {
  extra_args=()
  if [[ -n "$KEYFILE" ]]; then
    extra_args+=(--key-file "$KEYFILE")
  fi
}

_check_ttl_file() {
  local file="$1"
  [[ -z "${KPXC_TTL:-}" ]] && return 0
  local mtime
  if mtime=$(stat -c %Y "$file" 2>/dev/null); then :
  elif mtime=$(stat -f %m "$file" 2>/dev/null); then :
  else return 0
  fi
  local age=$(( $(date +%s) - mtime ))
  if (( age > KPXC_TTL )); then
    echo "kpxc: cache expired (>${KPXC_TTL}s) - run 'kpxc unlock' again." >&2
    exit 1
  fi
}

# Parse a scope spec ("Email/x Email/y:Username,URL") into TAB-separated
# (path, field) pairs on stdout.
_parse_scope() {
  local spec="$*"
  local token
  for token in $spec; do
    local path field_list
    if [[ "$token" == *:* ]]; then
      path="${token%%:*}"
      field_list="${token#*:}"
    else
      path="$token"
      field_list="Password"
    fi
    local field
    IFS=, read -ra fields <<< "$field_list"
    for field in "${fields[@]}"; do
      printf '%s\t%s\n' "$path" "$field"
    done
  done
}

_load_scope_file() {
  [[ -f "$SCOPE_FILE" ]] || return 1
  _safe_perm_check "$SCOPE_FILE" || return 1
  local lines=()
  local line
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    # trim leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    lines+=("$line")
  done < "$SCOPE_FILE"
  if (( ${#lines[@]} == 0 )); then
    return 1
  fi
  printf '%s\n' "${lines[@]}"
  return 0
}

_save_scope_file() {
  local scope="$1"
  local dir
  dir=$(dirname -- "$SCOPE_FILE")
  install -d -m 0700 "$dir"
  install -m 600 /dev/null "$SCOPE_FILE"
  {
    cat <<'EOF'
# kpxc scope file - which entries 'kpxc unlock' should cache.
#
# One line per scope entry:
#   <path>                         cache the Password field
#   <path>:<field>                 cache one specific field
#   <path>:<field1>,<field2>,...   cache multiple fields
#
# Special: a single line `all` puts kpxc in master mode (full
# keepassxc-cli access; the master password is cached). Use with care.
#
# Edit by hand, or regenerate with: kpxc unlock --interactive

EOF
    local IFS_orig="$IFS"
    IFS=$'\n'
    for line in $scope; do
      printf '%s\n' "$line"
    done
    IFS="$IFS_orig"
  } > "$SCOPE_FILE"
}

# List all entries (not groups) in the database. Caller passes the cached
# master password on stdin.
_list_entries() {
  local pw="$1"
  _extra_args
  printf '%s\n' "$pw" \
    | keepassxc-cli ls -q -R "${extra_args[@]}" "$DB" 2>/dev/null \
    | grep -v '/$' \
    | sed '/^[[:space:]]*$/d'
}

# Interactive picker. Reads master pw, queries entries, presents an
# fzf-based multi-select prompt. Returns selection (one entry per line)
# on stdout, or "all" for master mode.
_pick_scope() {
  local pw="$1"

  if ! command -v fzf >/dev/null 2>&1; then
    cat >&2 <<'EOF'
kpxc: 'kpxc unlock' picker requires fzf.

Install it:
  Debian/Ubuntu: sudo apt install fzf
  Arch:          sudo pacman -S fzf
  Fedora:        sudo dnf install fzf
  macOS:         brew install fzf

Or skip the picker by pre-creating the scope file:
  $EDITOR ~/.config/kpxc/scope     # one entry per line
  chmod 600 ~/.config/kpxc/scope
  kpxc unlock                      # will use the file

Or use master mode:
  kpxc unlock --master
EOF
    return 1
  fi

  local entries
  entries=$(_list_entries "$pw")
  if [[ -z "$entries" ]]; then
    echo "kpxc: no entries found in database." >&2
    return 1
  fi

  local count
  count=$(printf '%s\n' "$entries" | wc -l)

  # Sentinel option for "all entries" -> master mode. Marked with a
  # leading character that can't appear in keepassxc paths.
  local all_marker='[ all entries -> master mode ]'

  local choice
  if ! choice=$(
    {
      printf '%s\n' "$all_marker"
      printf '%s\n' "$entries"
    } | fzf \
        --multi \
        --height=80% \
        --layout=reverse \
        --border \
        --prompt='kpxc> ' \
        --header=$'TAB to mark, ENTER to confirm, ESC to cancel.\nMark "[ all entries -> master mode ]" to cache the master password instead.' \
        --info=inline \
        --bind='ctrl-a:select-all,ctrl-d:deselect-all'
  ); then
    echo "kpxc: nothing selected." >&2
    return 1
  fi

  if [[ -z "$choice" ]]; then
    echo "kpxc: nothing selected." >&2
    return 1
  fi

  if grep -qxF "$all_marker" <<< "$choice"; then
    printf 'all\n'
    return 0
  fi

  printf '%s\n' "$choice"
}

# Write the master cache.
_write_master_cache() {
  local pw="$1"
  rm -f "$CACHE_MASTER" "$CACHE_SCOPED"
  install -m 600 /dev/null "$CACHE_MASTER"
  printf '%s\n' "$pw" > "$CACHE_MASTER"
}

# Write the scoped cache from a scope spec. Caller passes master pw via
# stdin to _list_entries; here we use it directly for keepassxc-cli show.
_write_scoped_cache() {
  local pw="$1" scope_spec="$2"
  rm -f "$CACHE_MASTER" "$CACHE_SCOPED"
  install -m 600 /dev/null "$CACHE_SCOPED"

  _extra_args
  local count=0 failed=0
  local path field
  while IFS=$'\t' read -r path field; do
    [[ -z "$path" ]] && continue
    local value
    if value=$(printf '%s\n' "$pw" | keepassxc-cli show -q "${extra_args[@]}" -a "$field" "$DB" -- "$path" 2>/dev/null); then
      local b64
      b64=$(printf '%s' "$value" | base64 -w0 2>/dev/null || printf '%s' "$value" | base64 | tr -d '\n')
      printf '%s\t%s\t%s\n' "$path" "$field" "$b64" >> "$CACHE_SCOPED"
      count=$((count + 1))
    else
      echo "kpxc: failed to fetch '$path:$field' - skipping." >&2
      failed=$((failed + 1))
    fi
  done < <(_parse_scope "$scope_spec")

  if (( count == 0 )); then
    rm -f "$CACHE_SCOPED"
    rmdir "$CACHE_DIR" 2>/dev/null || true
    return 1
  fi
  printf '%d %d\n' "$count" "$failed"
  return 0
}

_cmd_unlock() {
  local force_master=0
  local force_interactive=0
  local cli_scope_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --master)       force_master=1; shift ;;
      --interactive)  force_interactive=1; shift ;;
      --help|-h)
        cat >&2 <<'EOF'
Usage: kpxc unlock [--master] [--interactive] [<scope-spec>...]

Without args (default flow):
  - if a saved scope file exists -> use it (scope mode)
  - else                          -> interactive picker, save the choice

With <scope-spec> args:
  - one-off scope mode, does NOT update the saved scope file

With --master:
  - cache the master password (full keepassxc-cli access). Does NOT
    touch the saved scope file.

With --interactive:
  - run the picker and save the new choice, ignoring any existing
    saved scope.
EOF
        exit 0
        ;;
      --) shift; break ;;
      *)  cli_scope_args+=("$1"); shift ;;
    esac
  done
  cli_scope_args+=("$@")

  _require_db
  if [[ ! -f "$DB" ]]; then
    echo "kpxc: database not found: $DB" >&2
    exit 1
  fi
  if [[ ! -t 0 ]]; then
    echo "kpxc: 'unlock' requires a TTY for password entry." >&2
    exit 1
  fi

  install -d -m 0700 "$CACHE_DIR"

  local PW=""
  trap 'rm -f "$CACHE_MASTER" "$CACHE_SCOPED"; unset PW 2>/dev/null || true' ERR INT TERM

  IFS= read -rsp "KeePass master password: " PW
  echo

  _extra_args
  if ! printf '%s\n' "$PW" | keepassxc-cli ls -q "${extra_args[@]}" "$DB" >/dev/null 2>&1; then
    echo "kpxc: wrong password." >&2
    unset PW
    exit 1
  fi

  # Resolve mode and scope
  local mode scope_spec=""
  if (( force_master )); then
    mode="master"
  elif (( force_interactive )); then
    mode="interactive"
  elif (( ${#cli_scope_args[@]} > 0 )); then
    mode="scoped-oneshot"
    scope_spec="${cli_scope_args[*]}"
  else
    # No flags, no args: try saved scope file
    local saved
    if saved=$(_load_scope_file 2>/dev/null); then
      if [[ "$saved" == "all" ]]; then
        mode="master"
      else
        mode="scoped-saved"
        scope_spec="$saved"
      fi
    else
      mode="interactive"
    fi
  fi

  if [[ "$mode" == "interactive" ]]; then
    local picked
    if ! picked=$(_pick_scope "$PW"); then
      unset PW
      exit 1
    fi
    if [[ "$picked" == "all" ]]; then
      _save_scope_file "all"
      mode="master"
    else
      scope_spec="$picked"
      _save_scope_file "$picked"
      mode="scoped-new"
    fi
  fi

  case "$mode" in
    master)
      _write_master_cache "$PW"
      unset PW
      trap - ERR INT TERM
      echo "Cached master password (full keepassxc-cli access)."
      echo "Lives until reboot or 'kpxc lock'${KPXC_TTL:+ (or after ${KPXC_TTL}s)}."
      ;;
    scoped-saved|scoped-new|scoped-oneshot)
      local stats
      if ! stats=$(_write_scoped_cache "$PW" "$scope_spec"); then
        unset PW
        echo "kpxc: scope mode requested but no entries fetched. Cache not written." >&2
        exit 1
      fi
      unset PW
      trap - ERR INT TERM
      local count="${stats% *}" failed="${stats#* }"
      local suffix=""
      [[ "$failed" != "0" ]] && suffix=", $failed failed"
      case "$mode" in
        scoped-saved)
          echo "Cached $count scoped credential(s)$suffix from $SCOPE_FILE."
          ;;
        scoped-new)
          echo "Saved scope to $SCOPE_FILE."
          echo "Cached $count scoped credential(s)$suffix."
          ;;
        scoped-oneshot)
          echo "Cached $count scoped credential(s)$suffix (one-off, scope file unchanged)."
          ;;
      esac
      echo "Master password discarded. Cache lives until reboot or 'kpxc lock'${KPXC_TTL:+ (or after ${KPXC_TTL}s)}."
      ;;
  esac
}

_cmd_lock() {
  local cleared=0
  if [[ -f "$CACHE_MASTER" ]]; then rm -f "$CACHE_MASTER"; cleared=1; fi
  if [[ -f "$CACHE_SCOPED" ]]; then rm -f "$CACHE_SCOPED"; cleared=1; fi
  rmdir "$CACHE_DIR" 2>/dev/null || true
  if (( cleared )); then echo "Cache cleared"; else echo "(no cache)"; fi
}

_cmd_scope() {
  if [[ -f "$CACHE_SCOPED" ]]; then
    echo "Mode: scoped"
    echo "Cached entries:"
    while IFS=$'\t' read -r p f _; do
      printf '  %s:%s\n' "$p" "$f"
    done < "$CACHE_SCOPED"
  elif [[ -f "$CACHE_MASTER" ]]; then
    echo "Mode: master (full keepassxc-cli access)"
  else
    echo "(no cache - run 'kpxc unlock' first)"
  fi
  if [[ -f "$SCOPE_FILE" ]]; then
    if ! _safe_perm_check "$SCOPE_FILE" >/dev/null 2>&1; then
      echo "kpxc: refusing to read $SCOPE_FILE (group/world-writable). Run: chmod 600 '$SCOPE_FILE'" >&2
      exit 1
    fi
    echo
    echo "Saved scope ($SCOPE_FILE):"
    local saved
    saved=$(_load_scope_file 2>/dev/null) || return 0
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      printf '  %s\n' "$line"
    done <<< "$saved"
  fi
}

_lookup_scoped() {
  local want_path="$1" want_field="$2"
  [[ -f "$CACHE_SCOPED" ]] || return 1
  _check_ttl_file "$CACHE_SCOPED"
  local p f v
  while IFS=$'\t' read -r p f v; do
    if [[ "$p" == "$want_path" && "$f" == "$want_field" ]]; then
      printf '%s' "$v" | base64 -d
      return 0
    fi
  done < "$CACHE_SCOPED"
  return 1
}

_cmd_get() {
  local entry=""
  local field="Password"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -a)         field="$2"; shift 2 ;;
      --help|-h)  echo "Usage: kpxc get <entry-path> [-a <field>]"; exit 0 ;;
      --)         shift; break ;;
      -*)         echo "kpxc get: unknown flag '$1' (only -a is supported here; for full keepassxc-cli show options use 'kpxc show')." >&2; exit 2 ;;
      *)          if [[ -z "$entry" ]]; then entry="$1"; else echo "kpxc get: unexpected extra argument '$1'." >&2; exit 2; fi; shift ;;
    esac
  done

  if [[ -z "$entry" ]]; then
    echo "Usage: kpxc get <entry-path> [-a <field>]" >&2
    exit 2
  fi

  if _lookup_scoped "$entry" "$field"; then
    return 0
  fi

  if [[ -f "$CACHE_SCOPED" ]]; then
    echo "kpxc: '$entry:$field' not in current scope." >&2
    echo "  Run 'kpxc scope' to see what's available," >&2
    echo "  or re-unlock with: kpxc unlock --interactive" >&2
    exit 1
  fi

  if [[ -f "$CACHE_MASTER" ]]; then
    _check_ttl_file "$CACHE_MASTER"
    _require_db
    _extra_args
    exec keepassxc-cli show -q "${extra_args[@]}" -a "$field" "$DB" -- "$entry" < "$CACHE_MASTER"
  fi

  echo "kpxc: no cached credentials - run 'kpxc unlock' first." >&2
  exit 1
}

_usage() {
  cat >&2 <<'EOF'
Usage:
  kpxc unlock [--master] [--interactive] [<scope-spec>...]
                                # scope mode by default. First unlock
                                # prompts you to pick which entries.
  kpxc lock                     # clear all caches
  kpxc get <entry> [-a <field>]
                                # read cached value (default field: Password)
  kpxc scope                    # show what's cached
  kpxc <subcmd> [args...]       # forward to keepassxc-cli (master mode only)

Scope-spec syntax:
  Email/personal                  default field (Password)
  Email/personal:Username         specific field
  Email/personal:Password,URL     multiple fields on one entry

Examples:
  kpxc unlock                                # picker on first run, then saved
  kpxc unlock --interactive                  # re-pick scope
  kpxc unlock Email/personal Backup/restic   # one-off scope (not saved)
  kpxc unlock --master                       # cache master password
  kpxc get Email/personal
  kpxc get Email/personal -a Username
  kpxc ls /Email                             # requires master mode
  kpxc lock
EOF
  exit 2
}

[[ $# -lt 1 ]] && _usage

SUBCMD="$1"; shift

case "$SUBCMD" in
  unlock) _cmd_unlock "$@"; exit 0 ;;
  lock)   _cmd_lock   "$@"; exit 0 ;;
  get)    _cmd_get    "$@" ;;
  scope)  _cmd_scope  "$@"; exit 0 ;;
esac

case "$SUBCMD" in
  estimate|generate|diceware|help|--help|-h|--version|-v)
    exec keepassxc-cli "$SUBCMD" "$@"
    ;;
esac

for arg in "$@"; do
  case "$arg" in
    --) break ;;
    --help|-h) exec keepassxc-cli "$SUBCMD" "$@" ;;
  esac
done

case "$SUBCMD" in
  db-create|import|open|close|merge)
    cat >&2 <<EOF
kpxc: '$SUBCMD' has a non-standard argument shape and is not safe to wrap.
Invoke keepassxc-cli directly:

  keepassxc-cli $SUBCMD ...
EOF
    exit 2
    ;;
esac

case "$SUBCMD" in
  add|edit)
    for arg in "$@"; do
      case "$arg" in
        -p|--password-prompt)
          cat >&2 <<EOF
kpxc: '$SUBCMD -p' needs interactive entry-password input that this wrapper
cannot supply from the cache. Invoke keepassxc-cli directly, or use
'$SUBCMD -g' for a generated password.
EOF
          exit 2
          ;;
      esac
    done
    ;;
  db-edit)
    for arg in "$@"; do
      case "$arg" in
        -p|--set-password)
          cat >&2 <<EOF
kpxc: '$SUBCMD $arg' needs interactive password input. Invoke keepassxc-cli
directly.
EOF
          exit 2
          ;;
      esac
    done
    ;;
esac

if [[ ! -f "$CACHE_MASTER" ]]; then
  if [[ -f "$CACHE_SCOPED" ]]; then
    cat >&2 <<EOF
kpxc: '$SUBCMD' needs the master password but only a scoped cache is active.
Re-unlock with full access:

  kpxc unlock --master

(or edit your saved scope: kpxc unlock --interactive)
EOF
    exit 1
  fi
  echo "kpxc: no cached credentials - run 'kpxc unlock' first." >&2
  exit 1
fi

_check_ttl_file "$CACHE_MASTER"
_require_db
_extra_args

exec keepassxc-cli "$SUBCMD" "${extra_args[@]}" "$DB" "$@" < "$CACHE_MASTER"
