#!/usr/bin/env bash
# kpxc - generic wrapper around keepassxc-cli using the cached master password.
#
# Usage:
#   kpxc <subcommand> [args...]
#
# Streams the cached master password from /dev/shm/<uid>-kpxc on stdin,
# so subcommands that need an unlocked database don't reprompt.
#
# Examples:
#   kpxc ls /Email
#   kpxc search foo
#   kpxc show -a Password Servers/prod
#   kpxc db-info
#
# Run 'kpunlock' first to populate the cache. For the show -a Password
# hot path used in scripts, prefer 'kpget' (shorter syntax).
#
# Configuration: see kpunlock(1).

set -euo pipefail

CACHE="${KP_CACHE:-/dev/shm/$(id -u)-kpxc}"
CONFIG="${KP_CONFIG:-$HOME/.config/kpxc/config}"

_safe_source() {
  local cfg="$1"
  [[ -f "$cfg" ]] || return 0
  if [[ ! -O "$cfg" ]]; then
    echo "kpxc: refusing to source $cfg (not owned by you)." >&2
    return 1
  fi
  local mode
  mode=$(stat -c '%a' "$cfg" 2>/dev/null) || mode=$(stat -f '%OLp' "$cfg" 2>/dev/null) || mode=""
  if [[ -z "$mode" ]]; then
    echo "kpxc: cannot stat $cfg" >&2
    return 1
  fi
  if (( 8#$mode & 022 )); then
    echo "kpxc: refusing to source $cfg (mode $mode, group/world-writable)." >&2
    return 1
  fi
  # shellcheck source=/dev/null
  source "$cfg"
}

_safe_source "$CONFIG"

DB="${KP_DB:-}"
KEYFILE="${KP_KEYFILE:-}"

_usage() {
  cat >&2 <<EOF
Usage: kpxc <subcommand> [args...]

Wraps keepassxc-cli with the cached master password from $CACHE.
Run 'kpunlock' first.

Examples:
  kpxc ls /Email
  kpxc search foo
  kpxc show -a Password Servers/prod
  kpxc db-info
EOF
  exit 2
}

[[ $# -lt 1 ]] && _usage

SUBCMD="$1"; shift

# 1. Subcommands that don't need an unlocked database, pass through directly.
case "$SUBCMD" in
  estimate|generate|diceware|help|--help|-h|--version|-v)
    exec keepassxc-cli "$SUBCMD" "$@"
    ;;
esac

# 2. Subcommand --help anywhere in args - skip DB injection so help renders.
for arg in "$@"; do
  case "$arg" in
    --help|-h)
      exec keepassxc-cli "$SUBCMD" "$@"
      ;;
  esac
done

# 3. Subcommands with non-standard argument shapes (DB position differs, or
#    creates a new database from another input). Wrapping these would either
#    fail with confusing errors or, worse, silently reorder args and target
#    the wrong file. Refuse and point at keepassxc-cli directly.
case "$SUBCMD" in
  db-create|import|open|close|merge)
    cat >&2 <<EOF
kpxc: '$SUBCMD' has a non-standard argument shape and is not safe to wrap.
Invoke keepassxc-cli directly:

  keepassxc-cli $SUBCMD ...
EOF
    exit 2
    ;;
esac

# 4. Subcommands that may prompt for additional passwords on stdin would
#    silently consume EOF (since cache holds only the master password) and
#    create entries with empty passwords. Refuse the password-prompt flags.
case "$SUBCMD" in
  add|edit)
    for arg in "$@"; do
      case "$arg" in
        -p|--password-prompt)
          cat >&2 <<EOF
kpxc: '$SUBCMD -p' needs interactive entry-password input that this wrapper
cannot supply from the cache. Invoke keepassxc-cli directly:

  keepassxc-cli $SUBCMD -p ...
EOF
          exit 2
          ;;
      esac
    done
    ;;
  db-edit)
    for arg in "$@"; do
      case "$arg" in
        -p|--set-password)
          cat >&2 <<EOF
kpxc: '$SUBCMD $arg' needs interactive password input. Invoke keepassxc-cli
directly:

  keepassxc-cli $SUBCMD $arg ...
EOF
          exit 2
          ;;
      esac
    done
    ;;
esac

if [[ -z "$DB" ]]; then
  echo "kpxc: no database configured (set \$KP_DB env var or KP_DB= in config)." >&2
  exit 1
fi

if [[ ! -f "$CACHE" ]]; then
  echo "kpxc: no cached master password - run 'kpunlock' first." >&2
  exit 1
fi

# Optional TTL check (portable mtime: GNU stat -c, BSD/macOS stat -f).
if [[ -n "${KP_TTL:-}" ]]; then
  if mtime=$(stat -c %Y "$CACHE" 2>/dev/null); then :
  elif mtime=$(stat -f %m "$CACHE" 2>/dev/null); then :
  else
    echo "kpxc: could not read cache mtime - run 'kpunlock' again." >&2
    exit 1
  fi
  age=$(( $(date +%s) - mtime ))
  if (( age > KP_TTL )); then
    echo "kpxc: cache expired (>${KP_TTL}s) - run 'kpunlock' again." >&2
    exit 1
  fi
fi

extra_args=()
[[ -n "$KEYFILE" ]] && extra_args+=(--key-file "$KEYFILE")

# Inject DB right after the subcommand. keepassxc-cli (Qt CommandLineParser)
# accepts options in any position, so this works for show/ls/search/db-info
# and the other unlock-required subcommands with the standard "subcmd database
# entry" shape.
exec keepassxc-cli "$SUBCMD" "${extra_args[@]}" "$DB" "$@" < "$CACHE"
