#!/usr/bin/env bash
# kpxc - cached wrapper around keepassxc-cli with two unlock modes:
#
#   scoped: cache only specific entries' fields. Master password is used
#           briefly during unlock and then discarded. An attacker reading
#           the cache only gets the scoped credentials, not the master pw.
#           The default if KPXC_DEFAULT_SCOPE is set, or if scope args are
#           passed to `kpxc unlock`.
#
#   master: cache the master password. Allows any keepassxc-cli subcommand
#           with the cache (ls, search, add, etc.). Trade-off: the master
#           password sits in tmpfs until lock; an attacker reading the
#           cache can decrypt the entire database. Use for interactive
#           sessions or when you genuinely need full DB access. Activated
#           by `kpxc unlock --master`.
#
# Subcommands:
#   kpxc unlock [--master] [<scope-spec>...]   cache credentials
#   kpxc lock                                  clear all caches
#   kpxc get <entry> [-a <field>]              read a cached value
#   kpxc scope                                 show what's cached (no values)
#   kpxc <keepassxc-subcmd> [args...]          forward to keepassxc-cli
#                                              (requires master mode)
#
# Scope-spec syntax (config and CLI):
#   Email/personal                  default field (Password)
#   Email/personal:Username         specific field
#   Email/personal:Password,Username  multiple fields on one entry
#
# Configuration:
#   $KPXC_DB              path to .kdbx (required)
#   $KPXC_KEYFILE         optional key file
#   $KPXC_DEFAULT_SCOPE   default scope spec (space-separated entries)
#   $KPXC_TTL             optional cache TTL in seconds
#   $KPXC_CACHE           override cache directory (default /dev/shm/<uid>-kpxc.d)
#   $KPXC_RC              override config file path (default ~/.config/kpxc/config)

set -euo pipefail

CACHE_DIR="${KPXC_CACHE:-/dev/shm/$(id -u)-kpxc.d}"
CACHE_MASTER="$CACHE_DIR/master"
CACHE_SCOPED="$CACHE_DIR/scoped"
CONFIG="${KPXC_RC:-$HOME/.config/kpxc/config}"

_safe_source() {
  local cfg="$1"
  [[ -f "$cfg" ]] || return 0
  if [[ ! -O "$cfg" ]]; then
    echo "kpxc: refusing to source $cfg (not owned by you)." >&2
    return 1
  fi
  local mode
  mode=$(stat -c '%a' "$cfg" 2>/dev/null) || mode=$(stat -f '%OLp' "$cfg" 2>/dev/null) || mode=""
  if [[ -z "$mode" ]]; then
    echo "kpxc: cannot stat $cfg" >&2
    return 1
  fi
  if (( 8#$mode & 022 )); then
    echo "kpxc: refusing to source $cfg (mode $mode, group/world-writable)." >&2
    return 1
  fi
  # shellcheck source=/dev/null
  source "$cfg" || true
  return 0
}

_safe_source "$CONFIG"

DB="${KPXC_DB:-}"
KEYFILE="${KPXC_KEYFILE:-}"
DEFAULT_SCOPE="${KPXC_DEFAULT_SCOPE:-}"

# Migration: v0.3.x used a single file at /dev/shm/<uid>-kpxc. If we find
# such a file at the path our directory should occupy, refuse rather than
# silently shred user state.
if [[ -f "$CACHE_DIR" ]]; then
  echo "kpxc: legacy v0.3.x cache file at $CACHE_DIR conflicts with the new" >&2
  echo "  cache-directory layout. Remove it: rm '$CACHE_DIR'" >&2
  exit 1
fi

_require_db() {
  if [[ -z "$DB" ]]; then
    echo "kpxc: no database configured (set \$KPXC_DB env var or KPXC_DB= in $CONFIG)." >&2
    exit 1
  fi
}

_extra_args() {
  extra_args=()
  if [[ -n "$KEYFILE" ]]; then
    extra_args+=(--key-file "$KEYFILE")
  fi
}

_check_ttl_file() {
  local file="$1"
  [[ -z "${KPXC_TTL:-}" ]] && return 0
  local mtime
  if mtime=$(stat -c %Y "$file" 2>/dev/null); then :
  elif mtime=$(stat -f %m "$file" 2>/dev/null); then :
  else return 0
  fi
  local age=$(( $(date +%s) - mtime ))
  if (( age > KPXC_TTL )); then
    echo "kpxc: cache expired (>${KPXC_TTL}s) - run 'kpxc unlock' again." >&2
    exit 1
  fi
}

# Parse a scope spec ("Email/x Email/y:Username,URL") into TAB-separated
# (path, field) pairs on stdout, one per line.
_parse_scope() {
  local spec="$*"
  local token
  for token in $spec; do
    local path field_list
    if [[ "$token" == *:* ]]; then
      path="${token%%:*}"
      field_list="${token#*:}"
    else
      path="$token"
      field_list="Password"
    fi
    local field
    IFS=, read -ra fields <<< "$field_list"
    for field in "${fields[@]}"; do
      printf '%s\t%s\n' "$path" "$field"
    done
  done
}

_cmd_unlock() {
  local force_master=0
  local scope_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --master)   force_master=1; shift ;;
      --help|-h)  echo "Usage: kpxc unlock [--master] [<scope-spec>...]"; exit 0 ;;
      --)         shift; break ;;
      *)          scope_args+=("$1"); shift ;;
    esac
  done
  scope_args+=("$@")

  local mode
  local scope_spec=""
  if (( force_master )); then
    mode="master"
  elif (( ${#scope_args[@]} > 0 )); then
    mode="scoped"
    scope_spec="${scope_args[*]}"
  elif [[ -n "$DEFAULT_SCOPE" ]]; then
    mode="scoped"
    scope_spec="$DEFAULT_SCOPE"
  else
    mode="master"
  fi

  _require_db
  if [[ ! -f "$DB" ]]; then
    echo "kpxc: database not found: $DB" >&2
    exit 1
  fi
  if [[ ! -t 0 ]]; then
    echo "kpxc: 'unlock' requires a TTY for password entry." >&2
    exit 1
  fi

  install -d -m 0700 "$CACHE_DIR"

  local PW=""
  trap 'rm -f "$CACHE_MASTER" "$CACHE_SCOPED"; unset PW 2>/dev/null || true' ERR INT TERM

  IFS= read -rsp "KeePass master password: " PW
  echo

  _extra_args
  if ! printf '%s\n' "$PW" | keepassxc-cli ls -q "${extra_args[@]}" "$DB" >/dev/null 2>&1; then
    echo "kpxc: wrong password." >&2
    unset PW
    exit 1
  fi

  rm -f "$CACHE_MASTER" "$CACHE_SCOPED"

  if [[ "$mode" == "master" ]]; then
    install -m 600 /dev/null "$CACHE_MASTER"
    printf '%s\n' "$PW" > "$CACHE_MASTER"
    unset PW
    trap - ERR INT TERM
    echo "Cached master password (full keepassxc-cli access)."
    echo "Lives until reboot or 'kpxc lock'${KPXC_TTL:+ (or after ${KPXC_TTL}s)}."
    return 0
  fi

  # Scope mode
  install -m 600 /dev/null "$CACHE_SCOPED"

  local count=0
  local failed=0
  while IFS=$'\t' read -r path field; do
    [[ -z "$path" ]] && continue
    local value
    if value=$(printf '%s\n' "$PW" | keepassxc-cli show -q "${extra_args[@]}" -a "$field" "$DB" -- "$path" 2>/dev/null); then
      local b64
      b64=$(printf '%s' "$value" | base64 -w0 2>/dev/null || printf '%s' "$value" | base64 | tr -d '\n')
      printf '%s\t%s\t%s\n' "$path" "$field" "$b64" >> "$CACHE_SCOPED"
      count=$((count + 1))
    else
      echo "kpxc: failed to fetch '$path:$field' - skipping." >&2
      failed=$((failed + 1))
    fi
  done < <(_parse_scope "$scope_spec")

  unset PW
  trap - ERR INT TERM

  if (( count == 0 )); then
    rm -f "$CACHE_SCOPED"
    rmdir "$CACHE_DIR" 2>/dev/null || true
    echo "kpxc: scope mode requested but no entries fetched successfully. Cache empty, no lock written." >&2
    exit 1
  fi

  echo "Cached $count scoped credential(s)${failed:+, $failed failed}."
  echo "Run 'kpxc scope' to list, 'kpxc lock' to clear."
  echo "Master password discarded. Cache lives until reboot or 'kpxc lock'${KPXC_TTL:+ (or after ${KPXC_TTL}s)}."
}

_cmd_lock() {
  local cleared=0
  if [[ -f "$CACHE_MASTER" ]]; then rm -f "$CACHE_MASTER"; cleared=1; fi
  if [[ -f "$CACHE_SCOPED" ]]; then rm -f "$CACHE_SCOPED"; cleared=1; fi
  rmdir "$CACHE_DIR" 2>/dev/null || true
  if (( cleared )); then echo "Cache cleared"; else echo "(no cache)"; fi
}

_cmd_scope() {
  if [[ -f "$CACHE_SCOPED" ]]; then
    echo "Mode: scoped"
    echo "Entries:"
    while IFS=$'\t' read -r p f _; do
      printf '  %s:%s\n' "$p" "$f"
    done < "$CACHE_SCOPED"
  elif [[ -f "$CACHE_MASTER" ]]; then
    echo "Mode: master (full keepassxc-cli access)"
  else
    echo "(no cache - run 'kpxc unlock' first)"
  fi
}

# Lookup in scoped cache. Returns 0 + prints value if found, 1 otherwise.
_lookup_scoped() {
  local want_path="$1" want_field="$2"
  [[ -f "$CACHE_SCOPED" ]] || return 1
  _check_ttl_file "$CACHE_SCOPED"
  local p f v
  while IFS=$'\t' read -r p f v; do
    if [[ "$p" == "$want_path" && "$f" == "$want_field" ]]; then
      printf '%s' "$v" | base64 -d
      return 0
    fi
  done < "$CACHE_SCOPED"
  return 1
}

_cmd_get() {
  local entry=""
  local field="Password"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -a)         field="$2"; shift 2 ;;
      --help|-h)  echo "Usage: kpxc get <entry-path> [-a <field>]"; exit 0 ;;
      --)         shift; break ;;
      -*)         echo "kpxc get: unknown flag '$1' (only -a is supported here; for full keepassxc-cli show options use 'kpxc show')." >&2; exit 2 ;;
      *)          if [[ -z "$entry" ]]; then entry="$1"; else echo "kpxc get: unexpected extra argument '$1'." >&2; exit 2; fi; shift ;;
    esac
  done

  if [[ -z "$entry" ]]; then
    echo "Usage: kpxc get <entry-path> [-a <field>]" >&2
    exit 2
  fi

  if _lookup_scoped "$entry" "$field"; then
    return 0
  fi

  if [[ -f "$CACHE_SCOPED" ]]; then
    echo "kpxc: '$entry:$field' not in current scope." >&2
    echo "  Run 'kpxc scope' to see what's available," >&2
    echo "  or re-unlock with: kpxc unlock $entry${field:+:$field} ..." >&2
    exit 1
  fi

  if [[ -f "$CACHE_MASTER" ]]; then
    _check_ttl_file "$CACHE_MASTER"
    _require_db
    _extra_args
    exec keepassxc-cli show -q "${extra_args[@]}" -a "$field" "$DB" -- "$entry" < "$CACHE_MASTER"
  fi

  echo "kpxc: no cached credentials - run 'kpxc unlock' first." >&2
  exit 1
}

_usage() {
  cat >&2 <<'EOF'
Usage:
  kpxc unlock [--master] [<scope-spec>...]
                                # cache credentials. Default: scope mode if
                                # KPXC_DEFAULT_SCOPE or scope args are given,
                                # else master mode.
  kpxc lock                    # clear cache
  kpxc get <entry> [-a <field>]
                                # read cached value (default field: Password)
  kpxc scope                   # show what's cached
  kpxc <subcmd> [args...]      # forward to keepassxc-cli (requires master mode)

Scope-spec syntax:
  Email/personal                  # default field (Password)
  Email/personal:Username         # specific field
  Email/personal:Password,URL     # multiple fields on one entry

Examples:
  kpxc unlock                                # scope-mode if KPXC_DEFAULT_SCOPE set
  kpxc unlock Email/personal Backup/restic   # ad-hoc scope mode
  kpxc unlock --master                       # master mode (full access)
  kpxc get Email/personal
  kpxc get Email/personal -a Username
  kpxc ls /Email                             # requires master mode
  kpxc lock
EOF
  exit 2
}

[[ $# -lt 1 ]] && _usage

SUBCMD="$1"; shift

case "$SUBCMD" in
  unlock) _cmd_unlock "$@"; exit 0 ;;
  lock)   _cmd_lock   "$@"; exit 0 ;;
  get)    _cmd_get    "$@" ;;
  scope)  _cmd_scope  "$@"; exit 0 ;;
esac

case "$SUBCMD" in
  estimate|generate|diceware|help|--help|-h|--version|-v)
    exec keepassxc-cli "$SUBCMD" "$@"
    ;;
esac

for arg in "$@"; do
  case "$arg" in
    --) break ;;
    --help|-h) exec keepassxc-cli "$SUBCMD" "$@" ;;
  esac
done

case "$SUBCMD" in
  db-create|import|open|close|merge)
    cat >&2 <<EOF
kpxc: '$SUBCMD' has a non-standard argument shape and is not safe to wrap.
Invoke keepassxc-cli directly:

  keepassxc-cli $SUBCMD ...
EOF
    exit 2
    ;;
esac

case "$SUBCMD" in
  add|edit)
    for arg in "$@"; do
      case "$arg" in
        -p|--password-prompt)
          cat >&2 <<EOF
kpxc: '$SUBCMD -p' needs interactive entry-password input that this wrapper
cannot supply from the cache. Invoke keepassxc-cli directly, or use
'$SUBCMD -g' for a generated password.
EOF
          exit 2
          ;;
      esac
    done
    ;;
  db-edit)
    for arg in "$@"; do
      case "$arg" in
        -p|--set-password)
          cat >&2 <<EOF
kpxc: '$SUBCMD $arg' needs interactive password input. Invoke keepassxc-cli
directly.
EOF
          exit 2
          ;;
      esac
    done
    ;;
esac

# Generic wrapper requires master mode.
if [[ ! -f "$CACHE_MASTER" ]]; then
  if [[ -f "$CACHE_SCOPED" ]]; then
    cat >&2 <<EOF
kpxc: '$SUBCMD' needs the master password but only a scoped cache is active.
For full keepassxc-cli access, re-unlock with:

  kpxc unlock --master
EOF
    exit 1
  fi
  echo "kpxc: no cached credentials - run 'kpxc unlock' first." >&2
  exit 1
fi

_check_ttl_file "$CACHE_MASTER"
_require_db
_extra_args

exec keepassxc-cli "$SUBCMD" "${extra_args[@]}" "$DB" "$@" < "$CACHE_MASTER"
